APP_USERNAME=admin
APP_PASSWORD=admin

# === PostgreSQL ===
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# === Redis ===
REDIS_PASSWORD=redis

# === RabbitMQ ===
RABBITMQ_DEFAULT_USER=rabbit
RABBITMQ_DEFAULT_PASS=rabbit

# === AIStor (ex-MinIO) ===
AISTOR_ROOT_USER=aistor
AISTOR_ROOT_PASSWORD=aistor-root-change-me
AISTOR_API_PORT=9000
# A imagem quay.io/minio/aistor/minio requer licença válida.
# Forneça UMA destas (deixe vazias enquanto avalia):
#   AISTOR_LICENSE        -> conteúdo da licença oferline (string)
#   AISTOR_SUBNET_API_KEY -> chave do MinIO SUBNET para registro online
AISTOR_LICENSE=
AISTOR_SUBNET_API_KEY=

# === MongoDB ===
MONGO_INITDB_ROOT_USERNAME=mongo
MONGO_INITDB_ROOT_PASSWORD=mongo

# === SignOz (observabilidade — opt-in via `make signoz-up`) ===
SIGNOZ_UI_PORT=3301
SIGNOZ_OTLP_GRPC_PORT=4317
SIGNOZ_OTLP_HTTP_PORT=4318
SIGNOZ_CLICKHOUSE_USER=signoz
SIGNOZ_CLICKHOUSE_PASSWORD=signoz
# Assina tokens de sessao na UI do SignOz. Gere com: openssl rand -base64 32
SIGNOZ_JWT_SECRET=
# deployment.environment resource attribute estampado em toda telemetria
SIGNOZ_DEFAULT_ENV=dev

# === Data ===
DATA_DIR=./data

# === Network ===
INFRA_NETWORK_NAME=infra-shelf

# === Registry encryption ===
# Generate with: openssl rand -base64 32
INFRA_SHELF_SECRET=

# === S3 backups ===
# Leave BACKUP_S3_BUCKET empty to keep backups local only.
BACKUP_S3_BUCKET=
BACKUP_S3_REGION=us-east-1
BACKUP_S3_PREFIX=infra-shelf/backups
BACKUP_S3_ENDPOINT=
BACKUP_S3_FORCE_PATH_STYLE=false
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
