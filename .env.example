APP_USERNAME=admin
APP_PASSWORD=admin

# === PostgreSQL ===
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# === Redis ===
REDIS_PASSWORD=redis

# === RabbitMQ ===
RABBITMQ_DEFAULT_USER=rabbit
RABBITMQ_DEFAULT_PASS=rabbit

# === S3-compatible storage (opt-in: `make s3-up`) ===
# Defaults to open-source MinIO. To use a commercial AIStor build instead,
# uncomment the AIStor image line and provide a license below.
S3_IMAGE=minio/minio
# S3_IMAGE=quay.io/minio/aistor/minio:latest
AISTOR_ROOT_USER=aistor
AISTOR_ROOT_PASSWORD=aistor-root-change-me
AISTOR_API_PORT=9000
# Only needed for the commercial AIStor image. Provide ONE of (leave empty for MinIO):
#   AISTOR_LICENSE        -> offline license content (string)
#   AISTOR_SUBNET_API_KEY -> MinIO SUBNET key for online registration
AISTOR_LICENSE=
AISTOR_SUBNET_API_KEY=

# === MongoDB ===
MONGO_INITDB_ROOT_USERNAME=mongo
MONGO_INITDB_ROOT_PASSWORD=mongo

# === SignOz (observability — opt-in via `make signoz-up`) ===
SIGNOZ_UI_PORT=3301
SIGNOZ_OTLP_GRPC_PORT=4317
SIGNOZ_OTLP_HTTP_PORT=4318
SIGNOZ_CLICKHOUSE_USER=signoz
SIGNOZ_CLICKHOUSE_PASSWORD=signoz
# Signs session tokens in the SignOz UI. Generate with: openssl rand -base64 32
SIGNOZ_JWT_SECRET=
# deployment.environment resource attribute stamped on all telemetry
SIGNOZ_DEFAULT_ENV=dev

# === Data ===
DATA_DIR=./data

# === Network ===
INFRA_NETWORK_NAME=infra-shelf

# === Registry encryption ===
# Generate with: openssl rand -base64 32
INFRA_SHELF_SECRET=

# === S3 backups ===
# Leave BACKUP_S3_BUCKET empty to keep backups local only.
BACKUP_S3_BUCKET=
BACKUP_S3_REGION=us-east-1
BACKUP_S3_PREFIX=infra-shelf/backups
BACKUP_S3_ENDPOINT=
BACKUP_S3_FORCE_PATH_STYLE=false
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
